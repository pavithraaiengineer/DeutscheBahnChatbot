# Copy to .env and fill real secrets locally.
# Never commit .env.

PORT=8000
ENV=local

# DB Timetables API
DB_CLIENT_ID=
DB_API_KEY=
DB_TIMETABLES_BASE_URL=https://apis.deutschebahn.com/db-api-marketplace/apis/timetables/v1

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=debian-rag
PINECONE_DIMENSION=128

# Databricks
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=debian

# GCP
GCP_PROJECT_ID=
GCP_REGION=europe-west1
BIGQUERY_DATASET=debian_analytics
GCS_BUCKET=
